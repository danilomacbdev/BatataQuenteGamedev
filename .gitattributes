# ─────────────────────────────────────────────────────────────────────────────
# .gitattributes for a Unity project
#   • Normalizes line endings
#   • Treats Unity YAML assets as mergeable text (Unity SmartMerge)
#   • Routes large binary assets through Git LFS
# Assumes Unity defaults: Editor ▸ Asset Serialization = "Force Text" and
#   Version Control ▸ Mode = "Visible Meta Files".
# ─────────────────────────────────────────────────────────────────────────────

# Auto-detect text files; store as LF in the repo, check out native per OS.
* text=auto

# ── Macros ───────────────────────────────────────────────────────────────────
# Unity YAML assets: always LF (Unity writes LF), 3-way merge via UnityYAMLMerge.
[attr]unity-yaml text eol=lf merge=unityyamlmerge diff
# Binary assets stored in Git LFS (no EOL conversion, no textual diff/merge).
[attr]lfs        -text filter=lfs diff=lfs merge=lfs

# ── Unity YAML text assets ───────────────────────────────────────────────────
*.unity              unity-yaml
*.prefab             unity-yaml
*.asset              unity-yaml
*.meta               unity-yaml
*.mat                unity-yaml
*.anim               unity-yaml
*.controller         unity-yaml
*.overrideController unity-yaml
*.mask               unity-yaml
*.playable           unity-yaml
*.signal             unity-yaml
*.physicMaterial     unity-yaml
*.physicsMaterial2D  unity-yaml
*.renderTexture      unity-yaml
*.spriteatlas        unity-yaml
*.spriteatlasv2      unity-yaml
*.terrainlayer       unity-yaml
*.mixer              unity-yaml
*.preset             unity-yaml
*.guiskin            unity-yaml
*.fontsettings       unity-yaml
*.flare              unity-yaml
*.giparams           unity-yaml
*.lighting           unity-yaml
*.shadervariants     unity-yaml
*.scenetemplate      unity-yaml

# ── Other Unity text formats (JSON / asmdef / shaders) — keep LF, plain text ──
*.json          text eol=lf
*.inputactions  text eol=lf
*.asmdef        text eol=lf
*.asmref        text eol=lf
*.shadergraph   text eol=lf
*.shader        text
*.compute       text
*.cginc         text
*.hlsl          text
*.glslinc       text
*.cs            text diff=csharp

